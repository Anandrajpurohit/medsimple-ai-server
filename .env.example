# ============================================================
# MEDSIMPLE AI — Environment Variables
# Copy this to .env for local dev, or paste into Render dashboard
# ============================================================

# Claude / Anthropic API Key
CLAUDE_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXX

# Twilio credentials (from twilio.com/console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio WhatsApp number (with whatsapp: prefix)
# For sandbox: whatsapp:+14155238886
# For production: whatsapp:+YOUR_TWILIO_NUMBER
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Server port (Render sets this automatically)
PORT=3000
